# PostgreSQL connection for local warehouse staging loader.
# This matches the existing Project 2 PostgreSQL container:
# container: project2_postgres
# port:      5434

PGHOST=localhost
PGPORT=5434
PGDATABASE=marketing_analytics
PGUSER=project2
PGPASSWORD=project2

# Target schema where Gold/SCD2 Parquet outputs are loaded
PGSCHEMA=staging

# Lakehouse Gold base path
GOLD_BASE_PATH=data/gold
